<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Dreamine.UI.Wpf.Controls">
    <Style TargetType="{x:Type local:DreamineExpander}">
        <!--  [수정] 기본 폰트 속성들을 새로 만든 헤더 프로퍼티의 기본값으로 설정  -->
        <Setter Property="HeaderFontSize" Value="{Binding FontSize, RelativeSource={RelativeSource Self}}" />
        <Setter Property="HeaderFontWeight" Value="{Binding FontWeight, RelativeSource={RelativeSource Self}}" />
        <Setter Property="HeaderForeground" Value="{Binding Foreground, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DreamineExpander}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            x:Name="HeaderBorder"
                            Grid.Row="0"
                            Background="#D1E9FF"
                            BorderBrush="#C0C0C0"
                            BorderThickness="1"
                            CornerRadius="6">
                            <ToggleButton
                                x:Name="PART_Header"
                                Padding="4"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="{TemplateBinding HeaderFontSize}"
                                FontWeight="{TemplateBinding HeaderFontWeight}"
                                Foreground="{TemplateBinding HeaderForeground}"
                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">

                                <DockPanel>
                                    <Grid
                                        x:Name="PlusMinusIcon"
                                        Width="12"
                                        Height="12"
                                        Margin="8,0,4,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <!--  아이콘 색상도 HeaderForeground를 따라가도록 수정  -->
                                        <Rectangle
                                            Height="2"
                                            VerticalAlignment="Center"
                                            Fill="{Binding HeaderForeground, RelativeSource={RelativeSource TemplatedParent}}" />
                                        <Rectangle
                                            x:Name="VerticalBar"
                                            Width="2"
                                            HorizontalAlignment="Center"
                                            Fill="{Binding HeaderForeground, RelativeSource={RelativeSource TemplatedParent}}"
                                            RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Grid>
                                    <ContentPresenter
                                        x:Name="HeaderContentPresenter"
                                        Margin="5,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        ContentSource="Header" />
                                </DockPanel>
                            </ToggleButton>
                        </Border>

                        <!--  본문 영역: 이곳은 VsExpander의 기본 FontWeight, FontSize 등의 영향을 받음  -->
                        <Border
                            x:Name="PART_ContentWrapper"
                            Grid.Row="1"
                            Background="White"
                            BorderBrush="#C0C0C0"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,6,6"
                            Visibility="Collapsed">
                            <ContentPresenter
                                x:Name="PART_Content"
                                Margin="10,6"
                                Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>


                    <ControlTemplate.Triggers>
                        <!--  펼쳐졌을 때  -->
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="PART_ContentWrapper" Property="Visibility" Value="Visible" />

                            <!--  [수정] ToggleButton을 감싸는 HeaderBorder의 속성을 변경  -->
                            <Setter TargetName="HeaderBorder" Property="CornerRadius" Value="6,6,0,0" />
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="1,1,1,0" />

                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="VerticalBar"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            To="90"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="VerticalBar"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!--  ArrowPlacement 속성이 Right일 때의 트리거  -->
                        <Trigger Property="ArrowPlacement" Value="Right">
                            <Setter TargetName="PlusMinusIcon" Property="DockPanel.Dock" Value="Right" />
                            <Setter TargetName="PlusMinusIcon" Property="Margin" Value="4,0,8,0" />
                            <Setter TargetName="HeaderContentPresenter" Property="HorizontalAlignment" Value="Center" />
                            <Setter TargetName="HeaderContentPresenter" Property="Margin" Value="0,0,5,0" />
                        </Trigger>

                        <!--  ShowExpandIcon이 false일 경우 아이콘 숨김  -->
                        <Trigger Property="ShowExpandIcon" Value="False">
                            <Setter TargetName="PlusMinusIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>