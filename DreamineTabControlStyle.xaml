<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Dreamine.UI.Wpf.Converters;assembly=Dreamine.UI.Wpf"
    xmlns:local="clr-namespace:Dreamine.UI.Wpf.Controls;assembly=Dreamine.UI.Wpf.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  닫기 버튼 표시용 bool → Visibility 변환기  -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <Style TargetType="{x:Type local:DreamineTabControl}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#FF2D4A6E" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 탭 헤더 영역 -->
                        <Border Grid.Row="0"
                                Background="#FF0A1525"
                                BorderBrush="#FF2D4A6E"
                                BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Panel.ZIndex="1" />
                        </Border>

                        <!-- 컨텐츠 영역 -->
                        <Border Grid.Row="1"
                                Background="Transparent"
                                KeyboardNavigation.DirectionalNavigation="Contained"
                                KeyboardNavigation.TabIndex="2"
                                KeyboardNavigation.TabNavigation="Local">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="TabItem">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Foreground" Value="#FF8899AA" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="HeaderContent"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"
                                                  TextBlock.FontSize="{TemplateBinding FontSize}"
                                                  TextBlock.FontWeight="{TemplateBinding FontWeight}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF1E90FF" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FF162040" />
                                    <Setter Property="Foreground" Value="#FFCCE4FF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="{x:Type local:VsTabItem}">
        <Setter Property="FontSize" Value="{Binding TabHeaderFontSize, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:VsTabItem}">
                    <Border
                        Name="Bd"
                        Padding="6,2"
                        Background="{Binding TabHeaderBackground, RelativeSource={RelativeSource TemplatedParent}}"
                        BorderBrush="Gray"
                        BorderThickness="{Binding TabBorderThickness, RelativeSource={RelativeSource TemplatedParent}}"
                        CornerRadius="{Binding TabCornerRadius, RelativeSource={RelativeSource TemplatedParent}}">
                        <StackPanel
                            Margin="4,0,4,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Image
                                Width="16"
                                Height="16"
                                Margin="0,0,4,0"
                                Source="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}"
                                Visibility="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />

                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{Binding TabHeaderFontSize, RelativeSource={RelativeSource TemplatedParent}}"
                                FontWeight="SemiBold"
                                Foreground="#333"
                                Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}" />

                            <Button
                                x:Name="PART_Close"
                                Width="16"
                                Height="16"
                                Margin="6,0,0,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DreamineTabControl}}, Path=CloseTabCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                Content="✖"
                                FontSize="10"
                                ToolTip="탭 닫기"
                                Visibility="{Binding IsClosable, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{Binding TabHeaderSelectedBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter Property="Foreground" Value="Black" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFEBF4FC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>




</ResourceDictionary>